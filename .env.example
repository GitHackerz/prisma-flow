# PrismaFlow environment variables
# Copy to .env and fill in your values.

# ── Prisma / Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# ── PrismaFlow server ─────────────────────────────────────────────────────────
# Port the local dashboard server listens on (default: 5555)
# PRISMAFLOW_PORT=5555

# Log level: trace | debug | info | warn | error  (default: info)
# PRISMAFLOW_LOG_LEVEL=info

# Set to "off" to disable anonymous usage telemetry
# PRISMAFLOW_TELEMETRY=on

# ── Feature flags ─────────────────────────────────────────────────────────────
# Pro licence key — required to unlock risk analysis, webhooks, and audit log
# PRISMAFLOW_LICENCE_KEY=pf_live_xxxxxxxxxxxxxxxx

# ── Webhook notifications ─────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
