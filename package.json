{
  "name": "prisma-flow-root",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "turbo run build",
    "build:cli": "turbo run build --filter=prisma-flow",
    "build:dashboard": "turbo run build --filter=dashboard",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "security:audit": "npm audit --omit=dev --workspaces --audit-level=high",
    "prepare": "husky"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "next@16.2.9": {
      "postcss": "^8.5.15"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "prettier": "^3.9.3",
    "husky": "^9.1.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": ["biome check --write"],
    "*.{json,md,yaml,yml}": ["prettier --write"]
  }
}
