# PrismaFlow environment variables
# Copy to .env and fill in your local values. Never commit .env.

# ── Prisma / Database ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# ── PrismaFlow server ─────────────────────────────────────────────────────────
# Port the local dashboard server listens on (default: 5555)
# PRISMAFLOW_PORT=5555

# Log level: trace | debug | info | warn | error  (default: info)
# PRISMAFLOW_LOG_LEVEL=info

# Telemetry is disabled by default. Set to "on", "true", or "1" to opt in.
# PRISMAFLOW_TELEMETRY=on

# ── Local dashboard behavior ──────────────────────────────────────────────────
# Set to 1 or true to avoid opening a browser automatically.
# PRISMAFLOW_NO_OPEN=1

# ── CI risk threshold ─────────────────────────────────────────────────────────
# low | medium | high | critical
# PRISMAFLOW_RISK_THRESHOLD=medium
