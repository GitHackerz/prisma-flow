{
  "name": "prisma-flow",
  "version": "0.1.0",
  "description": "Visual Prisma migration management — safe, observable, production-ready",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/prisma-flow/prisma-flow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prisma-flow/prisma-flow.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/prisma-flow/prisma-flow/issues"
  },
  "keywords": ["prisma", "migrations", "database", "schema-drift", "cli", "dashboard", "devtools"],
  "files": ["dist", "public"],
  "bin": {
    "prisma-flow": "./dist/index.js",
    "pf": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/copy-dashboard.mjs && tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist public"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@prisma-flow/shared": "*",
    "@prisma/internals": "^5.22.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "hono": "^4.6.0",
    "open": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
