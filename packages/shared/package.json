{
  "name": "@prisma-flow/shared",
  "version": "0.1.0",
  "description": "Shared PrismaFlow schemas, types, and error classes.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "homepage": "https://github.com/prisma-flow/prisma-flow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prisma-flow/prisma-flow.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/prisma-flow/prisma-flow/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.0.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
